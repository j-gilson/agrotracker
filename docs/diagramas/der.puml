@startuml
header AgroTracker - Relatório Técnico (TCC)
title Diagrama Entidade-Relacionamento (DER) - Modelagem Arquitetural Atual

' Estilização profissional
hide circle
skinparam linetype ortho
skinparam roundcorner 5
skinparam shadowing false
skinparam class {
    BackgroundColor white
    ArrowColor #2E7D32
    BorderColor #1B5E20
    FontName "Arial"
}

entity "usuarios" as user {
  * id : UUID <<PK>>
  --
  * nome : VARCHAR(100)
  * email : VARCHAR(100) <<UNIQUE>>
  * senha : VARCHAR(255)
  * ativo : BOOLEAN
  * created_at : TIMESTAMP
}

entity "fazendas" as farm {
  * id : UUID <<PK>>
  --
  * nome : VARCHAR(100)
  * localizacao : VARCHAR(255)
  * created_at : TIMESTAMP
}

entity "membros_fazenda" as membership {
  * id : UUID <<PK>>
  --
  * fazenda_id : UUID <<FK>>
  * usuario_id : UUID <<FK>>
  * role : VARCHAR(20) -- ADMIN, FUNCIONARIO
  * ativo : BOOLEAN
  * created_at : TIMESTAMP
}

entity "convites" as invite {
  * id : UUID <<PK>>
  --
  * fazenda_id : UUID <<FK>>
  * email : VARCHAR(100)
  * role : VARCHAR(20)
  * token : VARCHAR(255)
  * status : VARCHAR(20) -- PENDING, ACCEPTED
  * created_at : TIMESTAMP
}

entity "animais" as animal {
  * id : UUID <<PK>>
  --
  * fazenda_id : UUID <<FK>>
  * codigo_identificacao : VARCHAR(100)
  * nome : VARCHAR(50)
  * raca : VARCHAR(50)
  * peso : DECIMAL(10,2)
  * data_nascimento : DATE
  * created_at : TIMESTAMP
  --
  UNIQUE(fazenda_id, codigo_identificacao)
}

entity "eventos_manejo" as event {
  * id : UUID <<PK>>
  --
  * animal_id : UUID <<FK>>
  * fazenda_id : UUID <<FK>>
  * tipo : VARCHAR(50) -- PESAGEM, VACINACAO, MEDICACAO, ETC
  * descricao : TEXT
  * data_evento : TIMESTAMP
  * criado_por : UUID <<FK>>
  * created_at : TIMESTAMP
}

entity "logs_auditoria" as audit {
  * id : UUID <<PK>>
  --
  * usuario_id : UUID <<FK>>
  * fazenda_id : UUID <<FK>>
  * entidade_tipo : VARCHAR(50)
  * entidade_id : UUID
  * acao : VARCHAR(20) -- CREATE, UPDATE, DELETE, LOGIN, LOGOUT, ETC
  * descricao : TEXT
  * before_state : JSON
  * after_state : JSON
  * changes : JSON
  * metadata : JSON
  * data_hora : TIMESTAMP
}

' Relacionamentos
user ||--o{ membership : "participa de"
farm ||--o{ membership : "possui equipe"
farm ||--o{ invite : "gera"
farm ||--o{ animal : "contém rebanho"
animal ||--o{ event : "sofre"
farm ||--o{ event : "registra atividade"
user ||--o{ event : "realiza"
user ||--o{ audit : "é responsável por"
farm ||--o{ audit : "é monitorada por"

@enduml
